# ──────────────────────────────────────────────
# NEURUH Notion Auto-Exporter — Environment Config
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Your Notion integration token
# Get it at: https://www.notion.so/my-integrations → New integration
# Capabilities required: Read content, Read user info
NOTION_TOKEN=ntn_xxx

# The page ID of your Source Hub page in Notion
# This is the page where your build sources are linked (checked checkboxes = export targets)
# Get the ID from the URL: notion.so/Your-Page-Title-<THIS_32_CHAR_ID>
SOURCE_HUB_PAGE_ID=your_source_hub_page_id_here

# Where exported markdown files will land on your machine
OUTPUT_DIR=./exports
